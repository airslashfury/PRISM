# Shared image for the `api` and `worker` services. The api/ routes themselves
# stay light (SQLAlchemy + psycopg + rasterio for terrain/profile), but the
# arq worker (api/worker.py) runs prism.corridor.generate_corridors and
# prism.sync.trigger.trigger_rescore, which pull in geopandas/scipy/networkx —
# included here so both services can share one image.
FROM python:3.11-slim

WORKDIR /app

# System libs required by rasterio's bundled GDAL
RUN apt-get update && apt-get install -y --no-install-recommends \
    libexpat1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "fastapi>=0.110" \
    "uvicorn[standard]>=0.27" \
    "SQLAlchemy>=2.0" \
    "psycopg[binary]>=3.1" \
    "python-dotenv>=1.0" \
    "numpy>=1.26" \
    "rasterio>=1.3" \
    "Pillow>=10.0" \
    "PyYAML>=6.0" \
    "anthropic>=0.39" \
    "requests>=2.31" \
    "redis>=5.0" \
    "arq>=0.26" \
    "slowapi>=0.1.9" \
    "pyproj>=3.6" \
    "shapely>=2.0" \
    "networkx>=3.2" \
    "scipy>=1.11" \
    "geopandas>=0.14" \
    "prometheus-client>=0.20" \
    "python-json-logger>=2.0.7"

COPY api ./api
COPY prism/__init__.py ./prism/__init__.py
COPY prism/config.py ./prism/config.py
COPY prism/cache.py ./prism/cache.py
COPY prism/llm.py ./prism/llm.py
COPY prism/report ./prism/report
COPY prism/load ./prism/load
COPY prism/corridor ./prism/corridor
COPY prism/sync ./prism/sync
COPY prism/resilience ./prism/resilience
COPY prism/terrain ./prism/terrain
COPY prism/graph ./prism/graph
COPY prism/assets ./prism/assets
COPY prism/playground ./prism/playground
COPY prism/provenance ./prism/provenance
COPY prism/validate ./prism/validate
COPY prism/citizen ./prism/citizen
COPY prism/ask ./prism/ask
COPY prism/sitefinder ./prism/sitefinder
COPY prism/economy ./prism/economy
COPY prism/optimize ./prism/optimize
COPY config ./config
COPY catalog ./catalog

EXPOSE 8000

HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/health').status==200 else 1)"

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
