# PostGIS (used by docker-compose and the loaders)
POSTGRES_DB=prism
POSTGRES_USER=prism
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Keystone WFS — PR government (OGP / PRITS), ~400 geodatasets
WFS_URL=http://geoserver2.pr.gov/geoserver/pr_geodata/wfs

# API keys
CENSUS_API_KEY=
ANTHROPIC_API_KEY=
